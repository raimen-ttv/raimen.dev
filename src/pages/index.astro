---
import Layout from '../layouts/Layout.astro';
import { about, site, socialLinks } from '../data/site';
---

<Layout title={site.title} description={site.description} url={site.url}>
  <header class="site-header">
    <div class="container nav-shell">
      <a class="brand" href="#top" aria-label="Raimen home">
        <img class="brand-mark" src="/images/raimen-profile.png" alt="" aria-hidden="true" />
        <span class="brand-copy">
          <span class="brand-domain">{site.domain}</span>
          <span class="brand-motto">Learn. Explore. Create.</span>
        </span>
      </a>
      <nav aria-label="Section navigation">
        <a href="#about">About</a>
        <a href="#socials">Socials</a>
      </nav>
    </div>
  </header>

  <main id="main" class="page-shell">
    <section id="top" class="hero">
      <div class="container hero-grid">
        <div class="hero-copy reveal is-visible">
          <h1>{site.heroTitle}</h1>
          <p>{site.heroText}</p>
        </div>

      </div>
    </section>

    <section id="about" class="content-section">
      <div class="container">
        <div class="section-heading reveal">
          <span class="eyebrow">About</span>
          <h2>Code, 3D prints, and strange little machines.</h2>
        </div>

        <div class="about-grid">
          <article class="panel about-copy reveal">
            {about.body.split('\n\n').map((paragraph) => <p set:html={paragraph}></p>)}
          </article>
        </div>
      </div>
    </section>

    <section id="socials" class="content-section socials-section">
      <div class="container">
        <div class="section-heading reveal">
          <span class="eyebrow">Socials</span>
          <h2>Find Me</h2>
        </div>

        <div class="social-grid">
          {socialLinks.map((social, index) => (
            <a
              class="social-icon-link panel reveal"
              style={`--delay: ${index * 0.08}s`}
              href={social.href}
              target={social.href?.startsWith('mailto:') ? undefined : '_blank'}
              rel={social.href?.startsWith('mailto:') ? undefined : 'noreferrer'}
              aria-label={social.label}
              title={social.label}
            >
              {social.icon === 'github' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.09 3.29 9.4 7.86 10.92.57.1.78-.25.78-.56 0-.27-.01-1.17-.02-2.12-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.29-5.25-5.74 0-1.27.46-2.31 1.2-3.12-.12-.3-.52-1.49.12-3.11 0 0 .98-.32 3.2 1.19a11.08 11.08 0 0 1 5.82 0c2.21-1.51 3.19-1.19 3.19-1.19.64 1.62.24 2.81.12 3.11.75.81 1.2 1.85 1.2 3.12 0 4.46-2.69 5.44-5.26 5.73.41.36.78 1.08.78 2.18 0 1.58-.02 2.85-.02 3.24 0 .31.2.67.79.56a11.53 11.53 0 0 0 7.85-10.92C23.5 5.66 18.35.5 12 .5Z"/>
                </svg>
              )}
              {social.icon === 'youtube' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M23.5 6.2a3.02 3.02 0 0 0-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.56A3.02 3.02 0 0 0 .5 6.2 31.2 31.2 0 0 0 0 12a31.2 31.2 0 0 0 .5 5.8 3.02 3.02 0 0 0 2.12 2.14C4.5 20.5 12 20.5 12 20.5s7.5 0 9.38-.56a3.02 3.02 0 0 0 2.12-2.14A31.2 31.2 0 0 0 24 12a31.2 31.2 0 0 0-.5-5.8ZM9.6 15.7V8.3l6.4 3.7-6.4 3.7Z"/>
                </svg>
              )}
              {social.icon === 'instagram' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 1.8A3.7 3.7 0 0 0 3.8 7.5v9a3.7 3.7 0 0 0 3.7 3.7h9a3.7 3.7 0 0 0 3.7-3.7v-9a3.7 3.7 0 0 0-3.7-3.7h-9Zm9.75 1.35a1.15 1.15 0 1 1 0 2.3 1.15 1.15 0 0 1 0-2.3ZM12 6.85A5.15 5.15 0 1 1 6.85 12 5.16 5.16 0 0 1 12 6.85Zm0 1.8A3.35 3.35 0 1 0 15.35 12 3.36 3.36 0 0 0 12 8.65Z"/>
                </svg>
              )}
              {social.icon === 'discord' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M20.3 4.37A16.76 16.76 0 0 0 16.2 3.1a11.66 11.66 0 0 0-.53 1.08 15.4 15.4 0 0 0-4.65 0 11.66 11.66 0 0 0-.53-1.08 16.76 16.76 0 0 0-4.1 1.27C3.8 8.3 3.1 12.13 3.37 15.9a16.9 16.9 0 0 0 5.03 2.53c.4-.55.75-1.13 1.05-1.74-.58-.22-1.14-.5-1.67-.82.14-.1.27-.2.4-.3 3.22 1.5 6.72 1.5 9.9 0 .14.12.27.22.4.3-.53.32-1.09.6-1.68.82.3.61.66 1.19 1.06 1.74a16.84 16.84 0 0 0 5.02-2.53c.32-4.37-.55-8.16-2.58-11.53ZM9.85 13.58c-.97 0-1.77-.9-1.77-2s.78-2 1.77-2c1 0 1.8.9 1.77 2 0 1.1-.78 2-1.77 2Zm4.3 0c-.98 0-1.77-.9-1.77-2s.78-2 1.77-2c1 0 1.79.9 1.77 2 0 1.1-.78 2-1.77 2Z"/>
                </svg>
              )}
              {social.icon === 'bluesky' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M12 10.62c-1.56-3.04-5.82-7.76-8.3-8.9C1.33.63.57 1.53.57 2.62c0 1.08.59 8.9.98 10.2.94 3.14 4.36 4.2 7.5 3.86.16-.02.32-.05.48-.08-.16.03-.31.06-.48.08-4.58.68-8.66 2.34-3.32 8.28 5.87-1.45 8.05-6.97 8.27-7.66.22.69 2.4 6.21 8.27 7.66 5.34-5.94 1.26-7.6-3.32-8.28a8.91 8.91 0 0 1-.48-.08c.16.03.32.06.48.08 3.14.34 6.56-.72 7.5-3.86.39-1.3.98-9.12.98-10.2 0-1.09-.76-1.99-3.13-.9-2.48 1.14-6.74 5.86-8.3 8.9Z"/>
                </svg>
              )}
              {social.icon === 'linkedin' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 3A1.97 1.97 0 1 0 5.3 6.94 1.97 1.97 0 0 0 5.25 3ZM20.44 12.55c0-3.46-1.85-5.07-4.32-5.07a3.73 3.73 0 0 0-3.36 1.85V8.5H9.38c.04.55 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.68.12-.92.27-.68.88-1.39 1.9-1.39 1.34 0 1.88 1.02 1.88 2.52V20h3.38v-7.45Z"/>
                </svg>
              )}
              {social.icon === 'twitch' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M3 2h18v12l-4 4h-4l-2 2H8v-2H3V2Zm16 11.17V4H5v11.99h4.5V18l2-2h4.67L19 13.17ZM15 7h2v5h-2V7Zm-5 0h2v5h-2V7Z"/>
                </svg>
              )}
              {social.icon === 'email' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="currentColor" d="M3 5h18a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Zm0 2v.01L12 13l9-5.99V7H3Zm18 10V9.24l-8.46 5.63a1 1 0 0 1-1.08 0L3 9.24V17h18Z"/>
                </svg>
              )}
              <span class="sr-only">{social.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-shell">
      <p>Software, systems, and experiments, built by Raimen.</p>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.18 },
    );

    for (const element of document.querySelectorAll('.reveal:not(.is-visible)')) {
      observer.observe(element);
    }
  </script>
</Layout>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 0 0;
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(16, 21, 31, 0.72);
    backdrop-filter: blur(18px);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.22);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.01em;
    font-family: 'Magistral', 'Space Grotesk', sans-serif;
  }

  .brand-copy {
    display: grid;
    gap: 0.05rem;
  }

  .brand-domain {
    line-height: 1;
  }

  .brand-motto {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--surface-muted);
    line-height: 1.1;
  }

  .brand-mark {
    display: block;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.24);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 1rem;
  }

  nav a {
    text-decoration: none;
    color: var(--surface-muted);
    font-size: 0.98rem;
  }

  nav a:hover {
    color: var(--surface-ink);
  }

  .page-shell {
    padding: 1.25rem 0 5.5rem;
  }

  .hero {
    padding: 3.1rem 0 2.25rem;
  }

  .hero-grid {
    display: block;
  }

  .hero-copy,
  .about-copy,
  .contact-grid {
    padding: 1.6rem;
  }

  .hero-copy {
    display: grid;
    align-content: start;
    gap: 1.25rem;
    min-height: auto;
    max-width: none;
  }

  .hero-copy h1 {
    max-width: none;
    width: 100%;
    font-size: clamp(4.5rem, 12vw, 9rem);
    line-height: 0.9;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .hero-copy p {
    max-width: 60ch;
    font-size: 1.08rem;
    color: var(--surface-muted);
  }

  .hero-actions,
  .footer-shell {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
  }

  .button,
  .footer-shell a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 3rem;
    padding: 0.78rem 1.1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .button:hover,
  .footer-shell a:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    color: #081018;
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    box-shadow: 0 18px 32px rgba(204, 74, 37, 0.24);
  }

  .button-secondary,
  .footer-shell a {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(22, 28, 37, 0.82);
  }

  .availability {
    font-size: 0.97rem;
    color: var(--highlight);
  }

  .social-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.25rem;
    height: 4.25rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(22, 28, 37, 0.82);
    color: var(--surface-ink);
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
    text-decoration: none;
  }

  .social-icon-link:hover {
    transform: translateY(-2px);
    border-color: rgba(56, 172, 218, 0.35);
    background: rgba(28, 35, 47, 0.95);
    color: var(--highlight);
  }

  .social-icon-link svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .contact-grid h2,
  .section-heading h2 {
    font-size: clamp(2.1rem, 4vw, 3.7rem);
    line-height: 0.94;
    letter-spacing: -0.035em;
  }

  .contact-grid p,
  .about-copy p {
    color: var(--surface-muted);
  }

  .content-section {
    padding: 2.4rem 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.5rem;
  }

  .about-copy {
    display: grid;
    gap: 1rem;
  }

  .lead {
    color: var(--surface-ink);
    font-size: 1.18rem;
  }

  .social-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(240px, 0.85fr);
    gap: 1.5rem;
    align-items: center;
  }

  .contact-grid > div {
    display: grid;
    gap: 1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-footer {
    padding: 0 0 2.5rem;
  }

  .footer-shell {
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--surface-muted);
  }

  @keyframes float {
    50% {
      transform: translateY(-12px);
    }
  }

  @media (max-width: 1024px) {
    .about-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }

  }

  @media (max-width: 720px) {
    .site-header {
      padding-top: 0.6rem;
    }

    .nav-shell,
    nav {
      align-items: flex-start;
    }

    .nav-shell {
      flex-direction: column;
      border-radius: 28px;
    }

    nav {
      width: 100%;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .page-shell {
      padding-top: 0.7rem;
    }

    .hero {
      padding-top: 0.85rem;
    }

    .hero-copy,
    .about-copy,
    .contact-grid {
      padding: 1.25rem;
    }

    .hero-copy h1 {
      font-size: clamp(3.4rem, 16vw, 5.8rem);
    }

    .social-grid {
      gap: 0.75rem;
    }

    .social-icon-link {
      width: 3.75rem;
      height: 3.75rem;
    }

    .social-card {
      min-height: auto;
    }

    .footer-shell {
      justify-content: flex-start;
    }
  }
</style>
