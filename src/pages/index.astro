---
import Layout from '../layouts/Layout.astro';
import { about, contact, portfolio, site, socialLinks } from '../data/site';
---

<Layout title={site.title} description={site.description} url={site.url}>
  <header class="site-header">
    <div class="container nav-shell">
      <a class="brand" href="#top" aria-label="Raimen home">
        <span class="brand-mark">R</span>
        <span>{site.domain}</span>
      </a>
      <nav aria-label="Section navigation">
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <a href="#socials">Socials</a>
      </nav>
    </div>
  </header>

  <main id="main" class="page-shell">
    <section id="top" class="hero">
      <div class="container hero-grid">
        <div class="hero-copy reveal is-visible">
          <span class="eyebrow">{site.eyebrow}</span>
          <h1>{site.heroTitle}</h1>
          <p>{site.heroText}</p>
          <div class="hero-actions">
            <a class="button button-primary" href={site.heroPrimaryCta.href}>
              {site.heroPrimaryCta.label}
            </a>
            <a class="button button-secondary" href={site.heroSecondaryCta.href}>
              {site.heroSecondaryCta.label}
            </a>
          </div>
          <p class="availability">{site.availability}</p>
        </div>

        <aside class="hero-card panel reveal is-visible" style="--delay: 0.12s">
          <p class="hero-card-label">At a glance</p>
          <div class="hero-orbit" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="hero-card-grid">
            {about.stats.map((stat) => (
              <article>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </article>
            ))}
          </div>
          <div class="hero-card-note">
            <h2>Built to grow with the work</h2>
            <p>
              The foundation is here for deeper case studies, sharper project breakdowns, and a stronger public-facing body of work as the portfolio expands.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <section id="about" class="content-section">
      <div class="container">
        <div class="section-heading reveal">
          <span class="eyebrow">About</span>
          <h2>Software, systems, and builds with a practical streak.</h2>
          <p>
            Raimen works across code, automation, hardware, and interactive systems, with an emphasis on things that are both technically solid and genuinely interesting.
          </p>
        </div>

        <div class="about-grid">
          <article class="panel about-copy reveal">
            <p class="lead">{about.intro}</p>
            {about.body.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
          </article>

          <aside class="panel about-highlights reveal" style="--delay: 0.12s">
            <h3>Focus areas</h3>
            <ul>
              {about.highlights.map((item) => <li>{item}</li>)}
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <section id="contact" class="content-section">
      <div class="container contact-grid panel reveal">
        <div>
          <span class="eyebrow">Contact</span>
          <h2>{contact.heading}</h2>
          <p>{contact.body}</p>
        </div>
        <div class="contact-actions">
          <a class="button button-primary" href={`mailto:${contact.email}`}>
            {contact.email}
          </a>
          <p>Fast, static, and easy to maintain — without sacrificing polish.</p>
        </div>
      </div>
    </section>

    <section id="socials" class="content-section socials-section">
      <div class="container">
        <div class="section-heading reveal">
          <span class="eyebrow">Socials</span>
          <h2>Find Raimen where the work is happening.</h2>
          <p>
            YouTube, GitHub, and direct contact are the best ways to keep up with what Raimen is building and exploring.
          </p>
        </div>

        <div class="social-grid">
          {socialLinks.map((social, index) => (
            <article class="panel social-card reveal" style={`--delay: ${index * 0.08}s`}>
              <div>
                <p class="social-label">{social.label}</p>
                <h3>{social.handle}</h3>
              </div>
              {social.href ? (
                <a href={social.href} target="_blank" rel="noreferrer">
                  Open profile
                </a>
              ) : (
                <span class="placeholder-link">Add profile URL</span>
              )}
              <p>{social.note}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-shell">
      <p>Software, systems, and experiments — built by Raimen.</p>
      <a href={`mailto:${contact.email}`}>Email Raimen</a>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.18 },
    );

    for (const element of document.querySelectorAll('.reveal:not(.is-visible)')) {
      observer.observe(element);
    }
  </script>
</Layout>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 0 0;
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(16, 21, 31, 0.72);
    backdrop-filter: blur(18px);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.22);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    color: #081018;
    background: linear-gradient(135deg, var(--accent), var(--highlight));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 1rem;
  }

  nav a {
    text-decoration: none;
    color: var(--surface-muted);
    font-size: 0.98rem;
  }

  nav a:hover {
    color: var(--surface-ink);
  }

  .page-shell {
    padding: 1.25rem 0 5.5rem;
  }

  .hero {
    padding: 3.1rem 0 2.25rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.85fr);
    gap: 1.7rem;
    align-items: stretch;
  }

  .hero-copy,
  .hero-card,
  .about-copy,
  .about-highlights,
  .project-card,
  .contact-grid,
  .social-card {
    padding: 1.6rem;
  }

  .hero-copy {
    display: grid;
    align-content: center;
    gap: 1.25rem;
    min-height: 600px;
  }

  .hero-copy h1 {
    max-width: 11ch;
    font-size: clamp(4rem, 9vw, 7.35rem);
    line-height: 0.92;
    font-weight: 800;
    letter-spacing: -0.045em;
  }

  .hero-copy p {
    max-width: 60ch;
    font-size: 1.08rem;
    color: var(--surface-muted);
  }

  .hero-actions,
  .project-links,
  .footer-shell {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
  }

  .button,
  .project-links a,
  .social-card a,
  .footer-shell a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 3rem;
    padding: 0.78rem 1.1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .button:hover,
  .project-links a:hover,
  .social-card a:hover,
  .footer-shell a:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    color: #081018;
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    box-shadow: 0 18px 32px rgba(204, 74, 37, 0.24);
  }

  .button-secondary,
  .project-links a,
  .social-card a,
  .footer-shell a {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(22, 28, 37, 0.82);
  }

  .availability {
    font-size: 0.97rem;
    color: var(--highlight);
  }

  .hero-card {
    position: relative;
    display: grid;
    gap: 1.4rem;
    overflow: hidden;
    min-height: 600px;
    background:
      linear-gradient(160deg, rgba(18, 24, 34, 0.98), rgba(22, 29, 41, 0.88)),
      var(--surface);
  }

  .hero-card-label,
  .social-label,
  .project-meta {
    color: var(--surface-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
  }

  .hero-orbit {
    position: absolute;
    inset: auto -1.5rem 1rem auto;
    width: 16rem;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px dashed rgba(255, 255, 255, 0.14);
  }

  .hero-orbit span {
    position: absolute;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--highlight));
    opacity: 0.82;
    animation: float 8s ease-in-out infinite;
  }

  .hero-orbit span:nth-child(1) {
    width: 1rem;
    height: 1rem;
    top: 14%;
    left: 22%;
  }

  .hero-orbit span:nth-child(2) {
    width: 1.3rem;
    height: 1.3rem;
    top: 58%;
    left: 72%;
    animation-delay: 1.2s;
  }

  .hero-orbit span:nth-child(3) {
    width: 2.2rem;
    height: 2.2rem;
    top: 72%;
    left: 18%;
    animation-delay: 2.2s;
  }

  .hero-card-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: 3.2rem;
  }

  .hero-card-grid article,
  .social-card,
  .project-card {
    border-radius: var(--radius-md);
    border: 1px solid rgba(32, 21, 17, 0.08);
    background: rgba(25, 31, 43, 0.74);
  }

  .hero-card-grid article {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
  }

  .hero-card-grid strong {
    font-size: 2rem;
    font-family: 'Fraunces', serif;
  }

  .hero-card-note {
    position: relative;
    display: grid;
    gap: 0.8rem;
    margin-top: auto;
  }

  .hero-card-note h2,
  .contact-grid h2,
  .section-heading h2 {
    font-size: clamp(2.1rem, 4vw, 3.7rem);
    line-height: 0.94;
    letter-spacing: -0.035em;
  }

  .hero-card-note p,
  .project-card p,
  .contact-grid p,
  .social-card p,
  .about-copy p,
  .about-highlights li {
    color: var(--surface-muted);
  }

  .content-section {
    padding: 2.4rem 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.8fr);
    gap: 1.5rem;
  }

  .about-copy {
    display: grid;
    gap: 1rem;
  }

  .lead {
    color: var(--surface-ink);
    font-size: 1.18rem;
  }

  .about-highlights {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .about-highlights h3,
  .project-card h3,
  .social-card h3 {
    font-size: 1.5rem;
    line-height: 1.02;
    letter-spacing: -0.025em;
  }

  .about-highlights ul,
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .about-highlights li,
  .tag-list li {
    padding: 0.75rem 0.9rem;
    border-radius: 999px;
    background: rgba(56, 172, 218, 0.12);
    border: 1px solid rgba(56, 172, 218, 0.18);
  }

  .portfolio-grid,
  .social-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.1rem;
  }

  .project-card {
    display: grid;
    gap: 1rem;
    grid-column: span 4;
  }

  .project-card.is-featured {
    grid-column: span 6;
  }

  .placeholder-link {
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    padding: 0.78rem 1.1rem;
    border-radius: 999px;
    border: 1px dashed rgba(255, 255, 255, 0.18);
    color: var(--surface-muted);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(240px, 0.85fr);
    gap: 1.5rem;
    align-items: center;
  }

  .contact-grid > div {
    display: grid;
    gap: 1rem;
  }

  .social-card {
    display: grid;
    gap: 1rem;
    grid-column: span 6;
    min-height: 220px;
  }

  .site-footer {
    padding: 0 0 2.5rem;
  }

  .footer-shell {
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--surface-muted);
  }

  @keyframes float {
    50% {
      transform: translateY(-12px);
    }
  }

  @media (max-width: 1024px) {
    .hero-grid,
    .about-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy,
    .hero-card {
      min-height: auto;
    }

    .project-card,
    .project-card.is-featured,
    .social-card {
      grid-column: span 6;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      padding-top: 0.6rem;
    }

    .nav-shell,
    nav {
      align-items: flex-start;
    }

    .nav-shell {
      flex-direction: column;
      border-radius: 28px;
    }

    nav {
      width: 100%;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .page-shell {
      padding-top: 0.7rem;
    }

    .hero {
      padding-top: 0.85rem;
    }

    .hero-copy,
    .hero-card,
    .about-copy,
    .about-highlights,
    .project-card,
    .contact-grid,
    .social-card {
      padding: 1.25rem;
    }

    .hero-copy h1 {
      font-size: clamp(3rem, 16vw, 4.9rem);
    }

    .hero-card-grid,
    .portfolio-grid,
    .social-grid {
      grid-template-columns: 1fr;
    }

    .project-card,
    .project-card.is-featured,
    .social-card {
      grid-column: auto;
    }

    .hero-card-grid article {
      min-height: 110px;
    }

    .social-card {
      min-height: auto;
    }

    .footer-shell {
      justify-content: flex-start;
    }
  }
</style>
